{
	"name": "marriage-system",
	"version": "0.1.0",
	"private": true,
	"scripts": {
		"dev": "npm-run-all --parallel dev:frontend dev:backend",
		"dev:frontend": "next dev",
		"dev:backend": "cross-env CONVEX_AGENT_MODE=anonymous convex dev",
		"build": "next build",
		"start": "next start",
		"lint": "biome check .",
		"format": "biome check --write .",
		"typecheck": "tsc --noEmit",
		"typecheck:convex": "tsc --noEmit -p convex",
		"test": "vitest run"
	},
	"dependencies": {
		"@auth/core": "^0.41.1",
		"@base-ui/react": "^1.5.0",
		"@convex-dev/auth": "^0.0.94",
		"@hookform/resolvers": "^5.4.0",
		"class-variance-authority": "^0.7.1",
		"clsx": "^2.1.1",
		"convex": "^1.40.0",
		"date-fns": "^4.4.0",
		"lucide-react": "^1.17.0",
		"next": "^16.2.7",
		"next-themes": "^0.4.6",
		"react": "19.2.7",
		"react-dom": "19.2.7",
		"react-hook-form": "^7.78.0",
		"shadcn": "^4.11.0",
		"sonner": "^2.0.7",
		"tailwind-merge": "^3.6.0",
		"tw-animate-css": "^1.4.0",
		"zod": "^4.4.3"
	},
	"devDependencies": {
		"@biomejs/biome": "^2.4.16",
		"@edge-runtime/vm": "^5.0.0",
		"@tailwindcss/postcss": "^4",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@testing-library/user-event": "^14.6.1",
		"@types/node": "^20",
		"@types/react": "^19",
		"@types/react-dom": "^19",
		"@vitejs/plugin-react": "^6.0.2",
		"convex-helpers": "^0.1.119",
		"convex-test": "^0.0.53",
		"cross-env": "^10.1.0",
		"jsdom": "^29.1.1",
		"npm-run-all2": "^9.0.1",
		"tailwindcss": "^4",
		"typescript": "^5",
		"vitest": "^4.1.8"
	}
}
